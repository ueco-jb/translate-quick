<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        The Activity is rendered as a floating dialog over the previous screen
        (launcher or whichever app was foreground). The window itself is
        transparent; the visible "card" is painted by the Compose Surface,
        which picks light/dark colors from MaterialTheme.

        windowMinWidthMinor/Major pin the dialog to ~94% of the screen edge so
        we get a small uniform margin without programmatic window sizing.
    -->
    <style name="Theme.OneButtonTranslate" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.45</item>
        <item name="android:windowMinWidthMajor">94%</item>
        <item name="android:windowMinWidthMinor">94%</item>
    </style>
</resources>
