<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <!--
      Android 11+ requires explicit package visibility to resolve the speech
      recognition Intent. Without this, Intent.resolveActivity returns null even
      when a recognizer service exists (e.g. Google's), and the mic button
      would always look unavailable.
    -->
    <queries>
        <!-- For SpeechRecognizer.isRecognitionAvailable / createSpeechRecognizer -->
        <intent>
            <action android:name="android.speech.RecognitionService" />
        </intent>
        <!-- For Intent(RecognizerIntent.ACTION_RECOGNIZE_SPEECH).resolveActivity -->
        <intent>
            <action android:name="android.speech.action.RECOGNIZE_SPEECH" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.OneButtonTranslate">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:noHistory="true"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.OneButtonTranslate">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
